# Dokploy → PipraPay Application → Environment
# DB_HOST = MariaDB service name in Dokploy (e.g. piprapay-mariadb), never localhost.

PORT=8080

# Optional: skip web installer after DB is ready (writes pp-config.php on start)
# PIPRAPAY_AUTO_DB_CONFIG=1
# DB_HOST=piprapay-mariadb
# DB_PORT=3306
# DB_DATABASE=piprapaydb
# DB_USERNAME=piprapay
# DB_PASSWORD=CHANGE_ME
# DB_PREFIX=pp_
